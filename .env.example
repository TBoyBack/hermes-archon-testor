# Hermes Archon Testor 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============== Hermes 配置 ==============
HERMES_API_KEY=sk-your-openai-api-key-here
HERMES_MODEL=gpt-4
HERMES_BASE_URL=https://api.openai.com/v1

# ============== 应用配置 ==============
HERMES_ENV=development
HERMES_LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here

# ============== 数据库配置 ==============
HERMES_DB_PASSWORD=hermes_dev_password

# ============== Docker 配置 ==============
# COMPOSE_PROJECT_NAME=hermes-archon-testor
